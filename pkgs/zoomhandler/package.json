{
  "name": "zoomhandler",
  "version": "1.0.3",
  "description": "The Best Discord Bot Events & Commands handler",
  "packageManager": "bun@1.3.11",
  "homepage": "https://github.com/TheOldZoom/ZoomHandler",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheOldZoom/ZoomHandler.git"
  },
  "bugs": {
    "url": "https://github.com/TheOldZoom/ZoomHandler/issues"
  },
  "keywords": [
    "discord.js",
    "djs",
    "discord",
    "bot",
    "discord-handler",
    "event-handler",
    "discord-js-v14",
    "djs-v14"
  ],
  "author": "TheOldZoom",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "discord.js": "^14.14.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "discord.js": "^14.14.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
